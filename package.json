{
  "name": "session-context-extractor",
  "version": "0.1.0",
  "description": "Auto-capture decision reasoning, error history, preferences, and relationships from agent sessions",
  "main": "dist/index.js",
  "keywords": ["memory","agent","context","decision-tracking","error-history","preferences"],
  "author": "Jason Klutts",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "v2:setup": "ts-node src/setup.ts",
    "v2": "ts-node src/v2.ts",
    "v2:distill": "ts-node src/v2.ts distill",
    "v2:list": "ts-node src/v2.ts list",
    "v2:query": "ts-node src/v2.ts query",
    "v2:start": "ts-node src/v2.ts start-cron",
    "v2:archive": "ts-node src/archiver.ts",
    "list": "ts-node src/cli.ts list",
    "query": "ts-node src/cli.ts query",
    "unverified": "ts-node src/cli.ts unverified",
    "verify": "ts-node src/cli.ts verify",
    "stale": "ts-node src/cli.ts stale",
    "export": "ts-node src/cli.ts export"
  },
  "dependencies": {
    "lunr": "^2.3.9",
    "node-cron": "^3.0.2",
    "sql.js": "^1.8.0"
  },
  "devDependencies": {
    "@types/lunr": "^2.3.5",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/sql.js": "^1.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}